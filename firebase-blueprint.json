        "bonusReward": { "type": "number" }
      }
    },
    "TargetHistory": {
      "title": "Target History",
      "description": "User completed targets logs",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "userId": { "type": "string" },
        "referralsAchieved": { "type": "number" },
        "bonusReward": { "type": "number" }
      }
    },
    "GatewayLog": {
      "title": "Gateway Log",
      "description": "Gateway daily transaction stats and log records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "gatewayId": { "type": "string" },
        "gatewayName": { "type": "string" }
      }
    }
  },
  "firestore": {
    "config": {
      "schema": "GlobalConfig",
      "description": "System config settings"
    },
    "users": {
      "schema": "User",
      "description": "User records"
    },
    "tasks": {
      "schema": "Task",
      "description": "Earning tasks list"
    },
    "submissions": {
      "schema": "TaskSubmission",
      "description": "User task completions"
    },
    "withdraws": {
      "schema": "WithdrawRequest",
      "description": "User withdraw requests"
    },
    "membershipRequests": {
      "schema": "MembershipRequest",
      "description": "User membership upgrade requests"
    },
    "depositRequests": {
      "schema": "DepositRequest",
      "description": "Deposit balance requests"
    },
    "transactions": {
      "schema": "Transaction",
