    },
    "telegramRequests": {
      "schema": "TelegramVerificationRequest",
      "description": "Telegram verification logs"
    },
    "targets": {
      "schema": "ReferralTarget",
      "description": "Assigned referral targets"
    },
    "targetHistories": {
      "schema": "TargetHistory",
